    "emails:mailinator": "node --experimental-sqlite tools/rewriteEmails.js",
    "users:resync-temp": "node --experimental-sqlite tools/resyncTempPasswords.js"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.1",
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.1.49",
    "@langchain/openai": "^1.4.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.4.5",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.11",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
