{
  "name": "salary-agent-backend",
  "version": "1.0.0",
  "description": "Multi-agent automation platform - v1 salary slip agent",
  "main": "src/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node --experimental-sqlite src/server.js",
    "dev": "node --watch --experimental-sqlite src/server.js",
    "migrate": "node --experimental-sqlite src/db/migrate.js",
    "seed": "node --experimental-sqlite src/db/seed.js",
    "test": "node --experimental-sqlite --test tests/",
