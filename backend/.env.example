# Server
PORT=4000
NODE_ENV=development

# Secrets - CHANGE THESE IN PRODUCTION
JWT_SECRET=change-me-long-random-string
SECRET_KEY=change-me-32-byte-key-for-aes256

# Database: sqlite (zero-setup dev) or pg (production)
DB_CLIENT=sqlite
# DATABASE_URL=postgres://user:pass@localhost:5432/salary_agent
# SQLITE_PATH=./data/app.db

# Seed admin login
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=Admin@123

# Set false to disable the cron scheduler (e.g. in tests)
SCHEDULER_ENABLED=true
